# Contact form submission endpoint (read by src/components/ContactForm.tsx)
#
# Now — Formspree: create a form at https://formspree.io and paste its URL:
VITE_FORM_ENDPOINT=https://formspree.io/f/your-form-id
#
# Later — Resend: point this at a serverless function that calls the Resend
# API server-side. The RESEND_API_KEY stays on the server and is never
# exposed to the client; only this public endpoint URL changes.
# VITE_FORM_ENDPOINT=/api/contact
